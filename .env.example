# API Configuration (Optional - APIs work without keys)
# These are optional as the app uses free public APIs

# Aladhan API (Prayer Times & Hijri Date)
# No API key required - free public API
ALADHAN_API_URL=https://api.aladhan.com/v1

# Open-Meteo API (Weather)
# No API key required - free public API
OPEN_METEO_API_URL=https://api.open-meteo.com/v1

# Quran.com API (Quranic Verses)
# No API key required - free public API
QURAN_API_URL=https://api.quran.com/api/v4

# MyMemory Translation API
# Free tier: 1000 requests/day
# No API key required for free tier
MYMEMORY_API_URL=https://api.mymemory.translated.net

# Nominatim OSM (Reverse Geocoding)
# No API key required - free public API
# IMPORTANT: Set a unique User-Agent
NOMINATIM_API_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=MadeenApp/1.0.0

# App Configuration
APP_NAME=Madeen
APP_VERSION=1.0.0

# Environment
NODE_ENV=development
